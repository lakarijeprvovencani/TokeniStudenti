{
  "name": "vajb-agent",
  "version": "1.0.0",
  "description": "OpenAI-compatible API proxy that uses Anthropic (Claude) with per-student API keys and usage logging",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "prestart": "node scripts/postinstall.js",
    "dev": "node --watch src/index.js",
    "test": "node test-backend.mjs",
    "build:web": "cd vajbagent-web && npm install --no-audit --no-fund && npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@upstash/redis": "^1.36.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.1.0",
    "openai": "^6.25.0",
    "resend": "^6.9.3",
    "stripe": "^14.0.0"
  }
}
