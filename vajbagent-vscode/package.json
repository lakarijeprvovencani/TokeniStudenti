{
  "name": "vajbagent",
  "displayName": "VajbAgent",
  "description": "AI coding asistent sa 7 modela — razume projekat, pise i menja kod, pokrece komande, Plan Mode, MCP, auto-fix, checkpoint/undo. Bez pretplate.",
  "version": "0.30.1",
  "publisher": "VajbAgent",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "assistant",
    "coding",
    "agent",
    "vajbagent"
  ],
  "icon": "media/icon.png",
  "activationEvents": ["onView:vajbagent.chatView"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vajbagent",
          "title": "VajbAgent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vajbagent": [
        {
          "type": "webview",
          "id": "vajbagent.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "vajbagent.newSession",
        "title": "VajbAgent: New Session"
      },
      {
        "command": "vajbagent.setApiKey",
        "title": "VajbAgent: Set API Key"
      },
      {
        "command": "vajbagent.explainSelection",
        "title": "VajbAgent: Objasni selektovani kod"
      },
      {
        "command": "vajbagent.revertAll",
        "title": "VajbAgent: Vrati sve promene (Undo)"
      },
      {
        "command": "vajbagent.stopGeneration",
        "title": "VajbAgent: Zaustavi generisanje"
      },
      {
        "command": "vajbagent.refactorSelection",
        "title": "VajbAgent: Refaktorisi selekciju"
      }
    ],
    "keybindings": [
      {
        "command": "vajbagent.newSession",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      },
      {
        "command": "vajbagent.stopGeneration",
        "key": "escape",
        "when": "focusedView == 'vajbagent.chatView'"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vajbagent.explainSelection",
          "when": "editorHasSelection",
          "group": "vajbagent@1"
        },
        {
          "command": "vajbagent.refactorSelection",
          "when": "editorHasSelection",
          "group": "vajbagent@2"
        }
      ]
    },
    "configuration": {
      "title": "VajbAgent",
      "properties": {
        "vajbagent.apiUrl": {
          "type": "string",
          "default": "https://vajbagent.com",
          "description": "VajbAgent API server URL"
        },
        "vajbagent.model": {
          "type": "string",
          "default": "vajb-agent-lite",
          "enum": [
            "vajb-agent-lite",
            "vajb-agent-turbo",
            "vajb-agent-pro",
            "vajb-agent-max",
            "vajb-agent-power",
            "vajb-agent-ultra",
            "vajb-agent-architect"
          ],
          "enumDescriptions": [
            "Lite — brz i jeftin, svakodnevno kodiranje",
            "Turbo — reasoning model, logika i debugging",
            "Pro — jak i pametan, ozbiljniji projekti",
            "Max — kompleksni zadaci i planiranje",
            "Power — flagship, najjaci nivo",
            "Ultra — premium, najzahtevniji zadaci",
            "Architect — full-stack arhitekta, cele aplikacije od nule"
          ],
          "description": "AI model za koriscenje"
        },
        "vajbagent.autoApprove.writeFile": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve write_file (kreiranje/prepisivanje fajlova)"
        },
        "vajbagent.autoApprove.replaceInFile": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve replace_in_file (izmene u fajlovima)"
        },
        "vajbagent.autoApprove.executeCommand": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve execute_command (pokretanje komandi)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "build:icon": "node scripts/build-icon.mjs"
  },
  "devDependencies": {
    "sharp": "^0.33.5",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "marked": "^17.0.4"
  }
}
