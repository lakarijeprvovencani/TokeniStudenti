{
  "name": "vajbagent",
  "displayName": "Vajb Agent",
  "description": "AI coding asistent: 7 modela (Lite do Architect), chat u VS Code, razume projekat, pise i menja kod, pokrece komande, Plan Mode, checklist, web pretraga, MCP, attach fajlova (PDF, slike), checkpoint/undo, auto-approve opcije. Bez pretplate.",
  "version": "1.6.0",
  "publisher": "VajbAgent",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "ai coding",
    "ai assistant",
    "ai agent",
    "code assistant",
    "code generation",
    "chat",
    "copilot",
    "copilot alternative",
    "cursor",
    "vajbagent",
    "vajb agent",
    "vajb",
    "coding agent",
    "mcp"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onView:vajbagent.chatView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vajbagent",
          "title": "Vajb Agent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vajbagent": [
        {
          "type": "webview",
          "id": "vajbagent.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "vajbagent.newSession",
        "title": "VajbAgent: New Session"
      },
      {
        "command": "vajbagent.setApiKey",
        "title": "VajbAgent: Set API Key"
      },
      {
        "command": "vajbagent.explainSelection",
        "title": "VajbAgent: Objasni selektovani kod"
      },
      {
        "command": "vajbagent.revertAll",
        "title": "VajbAgent: Vrati sve promene (Undo)"
      },
      {
        "command": "vajbagent.stopGeneration",
        "title": "VajbAgent: Zaustavi generisanje"
      },
      {
        "command": "vajbagent.refactorSelection",
        "title": "VajbAgent: Refaktorisi selekciju"
      }
    ],
    "keybindings": [
      {
        "command": "vajbagent.newSession",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      },
      {
        "command": "vajbagent.stopGeneration",
        "key": "escape",
        "when": "focusedView == 'vajbagent.chatView'"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vajbagent.explainSelection",
          "when": "editorHasSelection",
          "group": "vajbagent@1"
        },
        {
          "command": "vajbagent.refactorSelection",
          "when": "editorHasSelection",
          "group": "vajbagent@2"
        }
      ]
    },
    "configuration": {
      "title": "Vajb Agent",
      "properties": {
        "vajbagent.apiUrl": {
          "type": "string",
          "default": "https://vajbagent.com",
          "description": "VajbAgent API server URL"
        },
        "vajbagent.model": {
          "type": "string",
          "default": "vajb-agent-lite",
          "enum": [
            "vajb-agent-lite",
            "vajb-agent-turbo",
            "vajb-agent-pro",
            "vajb-agent-max",
            "vajb-agent-power",
            "vajb-agent-ultra",
            "vajb-agent-architect"
          ],
          "enumDescriptions": [
            "Lite \u2014 brz i jeftin, svakodnevno kodiranje",
            "Turbo \u2014 reasoning model, logika i debugging",
            "Pro \u2014 jak i pametan, ozbiljniji projekti",
            "Max \u2014 kompleksni zadaci i planiranje",
            "Power \u2014 flagship, najjaci nivo",
            "Ultra \u2014 premium, najzahtevniji zadaci",
            "Architect \u2014 full-stack arhitekta, cele aplikacije od nule"
          ],
          "description": "AI model za koriscenje"
        },
        "vajbagent.autoApprove.writeFile": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve write_file (kreiranje/prepisivanje fajlova)"
        },
        "vajbagent.autoApprove.replaceInFile": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve replace_in_file (izmene u fajlovima)"
        },
        "vajbagent.autoApprove.executeCommand": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve execute_command (pokretanje komandi)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "build:icon": "node scripts/build-icon.mjs",
    "test": "node ./out/test/runTest.js",
    "test:compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.1",
    "mocha": "^10.2.0",
    "sharp": "^0.33.5",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "jsonrepair": "^3.13.3",
    "marked": "^17.0.4"
  },
  "__metadata": {
    "installedTimestamp": 1774619877569,
    "targetPlatform": "undefined",
    "size": 1043307
  }
}
