{
  "name": "vajbagent",
  "displayName": "VajbAgent",
  "description": "AI coding asistent — cita, pise i menja kod umesto tebe. 7 modela, Plan Mode, MCP podrska.",
  "version": "0.7.0",
  "publisher": "VajbAgent",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "assistant",
    "coding",
    "agent",
    "vajbagent"
  ],
  "icon": "media/icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vajbagent",
          "title": "VajbAgent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vajbagent": [
        {
          "type": "webview",
          "id": "vajbagent.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "vajbagent.newSession",
        "title": "VajbAgent: New Session"
      },
      {
        "command": "vajbagent.setApiKey",
        "title": "VajbAgent: Set API Key"
      }
    ],
    "configuration": {
      "title": "VajbAgent",
      "properties": {
        "vajbagent.apiUrl": {
          "type": "string",
          "default": "https://vajbagent.com",
          "description": "VajbAgent API server URL"
        },
        "vajbagent.model": {
          "type": "string",
          "default": "vajb-agent-lite",
          "enum": [
            "vajb-agent-lite",
            "vajb-agent-turbo",
            "vajb-agent-pro",
            "vajb-agent-max",
            "vajb-agent-power",
            "vajb-agent-ultra",
            "vajb-agent-architect"
          ],
          "enumDescriptions": [
            "Lite — brz i jeftin, svakodnevno kodiranje",
            "Turbo — reasoning model, logika i debugging",
            "Pro — jak i pametan, ozbiljniji projekti",
            "Max — kompleksni zadaci i planiranje",
            "Power — flagship, najjaci nivo",
            "Ultra — premium, najzahtevniji zadaci",
            "Architect — full-stack arhitekta, cele aplikacije od nule"
          ],
          "description": "AI model za koriscenje"
        },
        "vajbagent.autoApprove.writeFile": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve write_file (kreiranje/prepisivanje fajlova)"
        },
        "vajbagent.autoApprove.replaceInFile": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve replace_in_file (izmene u fajlovima)"
        },
        "vajbagent.autoApprove.executeCommand": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve execute_command (pokretanje komandi)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "build:icon": "node scripts/build-icon.mjs"
  },
  "devDependencies": {
    "sharp": "^0.33.5",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "marked": "^17.0.4"
  }
}
