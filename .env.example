# Anthropic API key (ti plaćaš Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Opciono: Claude model (default claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Validni student API ključevi (Bearer tokeni), razdvojeni zarezom.
# Svaki student dobija jedan ključ; proxy proverava i loguje usage po ključu.
STUDENT_API_KEYS=student-key-1,student-key-2,student-key-3

# Opciono: port (default 3000)
PORT=3000

# Admin tajna za dodavanje kredita (POST /admin/add-credits, header X-Admin-Secret)
ADMIN_SECRET=your-secret-here

# Na Renderu: postavi DATA_DIR=/data ako koristiš Persistent Disk (da balance i usage prežive restart)
# DATA_DIR=/data

# Marža na studente: koliko puta više naplaćuješ od Anthropic cene (1 = bez marže).
# Npr. 1.5 = skidaš 1.5× više sa balansa; ti plaćaš Anthropic manje → razlika je tvoja zarada.
# STUDENT_MARKUP=1.5

# Stripe (za automatsko dodavanje kredita: 1 USD uplate = 1 USD kredita)
# STRIPE_SECRET_KEY=sk_live_...   (ili sk_test_...)
# STRIPE_WEBHOOK_SECRET=whsec_... (tajna za endpoint POST /webhooks/stripe)
# BASE_URL=https://tvoj-domen.com   (za success_url nakon plaćanja)
