# Anthropic API key – za Pro/Max/Ultra modele (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key – za Nano/Lite modele (GPT-5)
OPENAI_API_KEY=sk-...

# Validni student API ključevi (Bearer tokeni), razdvojeni zarezom.
STUDENT_API_KEYS=student-key-1,student-key-2,student-key-3

# Opciono: port (default 3000)
PORT=3000

# Admin tajna za dodavanje kredita i admin stranice
ADMIN_SECRET=your-secret-here

# Na Renderu: postavi DATA_DIR=/data ako koristiš Persistent Disk
# DATA_DIR=/data

# Marža po provideru (ako nisu postavljeni, koristi se STUDENT_MARKUP kao fallback)
# OPENAI_MARKUP=1.75
# ANTHROPIC_MARKUP=1.45
# STUDENT_MARKUP=1.65

# Bonus kredit za self-registraciju novih korisnika (default: 2 USD)
# SELF_REGISTER_BONUS=2

# Max naloga po IP adresi (default: 2) i max korisnika ukupno (default: 10000)
# MAX_REGISTRATIONS_PER_IP=2
# MAX_STUDENTS=10000

# IP adrese koje zaobilaze rate limiter i limit registracija (razdvojene zarezom)
# WHITELIST_IPS=1.2.3.4,5.6.7.8

# Stripe (za automatsko dodavanje kredita)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# BASE_URL=https://tvoj-domen.com

# Resend (za slanje emailova — welcome, recovery kljuca)
# Registruj se na https://resend.com (besplatno do 3000 emailova/mesec)
# RESEND_API_KEY=re_...
# EMAIL_FROM=VajbAgent <noreply@tvoj-domen.com>
